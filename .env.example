NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# Optional fallback if your workspace still uses the older variable name.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Recommended for server-side storage access in production.
SUPABASE_SERVICE_ROLE_KEY=

# Optional storage configuration.
SUPABASE_STORAGE_BUCKET=knowledge-base
SUPABASE_STORAGE_HISTORY_PREFIX=

# Reserved for the future backend integration stage.
RAG_BACKEND_BASE_URL=http://localhost:8000
